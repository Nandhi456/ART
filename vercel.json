{
  "services": {
    "frontend": { 
      "root": "frontend", 
      "framework": "vite" 
    },
    "backend": { 
      "root": "api", 
      "framework": "fastapi" 
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": { "service": "/backend/api" }
    },
    {
      "source": "/(.*)",
      "destination": { "service": "frontend" }
    }
  ]
}
